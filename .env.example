# -------- Core RPC ----------
RPC_HTTP_URL=https://your.rpc.endpoint

# -------- Shredstream proxy (local gRPC endpoints) ----------
# Comma-separated. You can run one proxy per region and list them all here.
# Example: http://127.0.0.1:50051,http://127.0.0.1:50052
SHREDSTREAM_PROXY_GRPC_URLS=http://127.0.0.1:50051

# -------- Filtering ----------
# Comma-separated leader wallets (Pubkeys). Leave empty to accept ALL Pump buys (not recommended).
LEADER_WALLETS=
# If true: leader must be a signer. If false: leader can appear anywhere in accounts (platform trades).
STRICT_SIGNER=false

# If true, attempt CPI/wrapper mint inference (GMGN/Trojan/Axiom). Slower but avoids missing trades.
CPI_HEURISTIC_MINT=false
# Print runtime stats every N seconds (0 disables)
STATS_INTERVAL_SECS=5
# Debug: log up to N leader tx signatures per stats interval (very noisy)
DEBUG_LEADER_SAMPLE=0

# Enable ALT resolution for v0 txs
RESOLVE_ALTS=true
# Max concurrent ALT fetches (protects your RPC from bursts)
ALT_MAX_CONCURRENT_FETCH=12
# Max concurrent tx parses per incoming batch
PARSE_CONCURRENCY=64

# Max concurrent executions (submit/build) so monitor/parse never blocks
EXECUTOR_CONCURRENCY=16

# Refresh cached recent blockhash (ms)
BLOCKHASH_REFRESH_MS=300

# Dedup: cross-region duplicates (signatures repeat). Short TTL is enough.
DEDUP_SIG_TTL_MS=2000
# Dedup per mint (avoid rebuy spam)
DEDUP_MINT_TTL_SECS=600

# -------- Execution ----------
# log | demo | pumpbuy
EXECUTION_MODE=log
BUY_SOL=0.1
SLIPPAGE_BPS=500
ONESHOT=false

# -------- Wallet ----------
# Provide ONE of these:
KEYPAIR_PATH=
WALLET_PRIVATE_KEY=
WALLET_PRIVATE_KEY_PATH=

# -------- Jito submission ----------
USE_JITO=true
JITO_BLOCK_ENGINE_URL=https://amsterdam.mainnet.block-engine.jito.wtf
JITO_UUID=
JITO_TIP_LAMPORTS=30000
# Optional: force a specific tip account. If empty, bot calls getTipAccounts and picks the first.
JITO_TIP_ACCOUNT=

# -------- RPC fallback submission (optional) ----------
DUAL_SUBMIT_RPC=false
RPC_SKIP_PREFLIGHT=true

# -------- Compute budget ----------
CU_LIMIT=600000
CU_PRICE_MICRO_LAMPORTS=0

# -------- Logging ----------
RUST_LOG=info
